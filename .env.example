# Base de données PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/certprep"

# NextAuth.js
# Générez un secret avec : openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-nextauth-a-changer-en-production"
NEXTAUTH_URL="http://localhost:3000"

# Auth Google (optionnel)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Auth GitHub (optionnel)
# GITHUB_ID=""
# GITHUB_SECRET=""

# Stripe (optionnel - pour les paiements)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# AWS S3 (optionnel - pour les uploads)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="eu-west-3"
# AWS_S3_BUCKET=""
